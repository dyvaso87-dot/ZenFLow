<Window x:Class="ZenFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZenFlow" Height="600" Width="900"
        Background="#F5F7FA">
    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#185FA5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#1F4E79">
            <TextBlock Text="ZenFlow" Foreground="White" FontSize="20"
                       FontWeight="Bold" Margin="20,24,0,24"/>
            <Button Content="📋  Tareas"  Tag="Tareas"
                    Style="{StaticResource NavBtn}" Click="NavClick"/>
            <Button Content="⏱  Enfoque" Tag="Enfoque"
                    Style="{StaticResource NavBtn}" Click="NavClick"/>
            <Button Content="💚  Hábitos" Tag="Habitos"
                    Style="{StaticResource NavBtn}" Click="NavClick"/>
        </StackPanel>

        <Frame Grid.Column="1" x:Name="MainFrame"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>