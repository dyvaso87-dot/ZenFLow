<Page x:Class="ZenFlow.Views.VistaHabitos"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Hábitos">
    <StackPanel Margin="30">
        <TextBlock Text="Mis hábitos" FontSize="22" FontWeight="Bold"
                   Foreground="#1F4E79" Margin="0,0,0,20"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox x:Name="TxtHabito" Width="300" Height="34"
                     Padding="8,6" FontSize="13" Margin="0,0,10,0"
                     BorderBrush="#CCCCCC" BorderThickness="1"/>
            <Button Content="Agregar hábito" Height="34" Padding="16,0"
                    Background="#1F4E79" Foreground="White"
                    BorderThickness="0" FontSize="13"
                    Click="AgregarHabito_Click"/>
        </StackPanel>
        <ListBox x:Name="ListaHabitos" FontSize="13"
                 BorderBrush="#CCCCCC" SelectionChanged="RegistrarCumplimiento"/>
        <TextBlock Text="Selecciona un hábito para registrar cumplimiento de hoy"
                   FontSize="11" Foreground="#777" Margin="0,8,0,0"/>
    </StackPanel>
</Page>