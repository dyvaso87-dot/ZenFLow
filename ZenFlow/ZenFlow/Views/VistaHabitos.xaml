<Page x:Class="ZenFlow.Views.VistaHabitos"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Hábitos" Background="#F5F7FA">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ENCABEZADO -->
        <TextBlock Grid.Row="0" Text="Mis hábitos" FontSize="24"
                   FontWeight="Bold" Foreground="#1F4E79" Margin="0,0,0,24"/>

        <!-- AGREGAR HÁBITO -->
        <Border Grid.Row="1" Background="White" CornerRadius="10"
                Padding="16" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtHabito" Grid.Column="0"
                         Height="36" Padding="10,8" FontSize="13"
                         Margin="0,0,10,0" BorderBrush="#DDDDDD"
                         BorderThickness="1" Background="#FAFAFA"
                         Tag="Nombre del hábito..."/>
                <Button Grid.Column="1" Content="+ Agregar"
                        Height="36" Padding="16,0"
                        FontSize="13" Cursor="Hand"
                        BorderThickness="0"
                        Click="AgregarHabito_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1F4E79"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#185FA5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- LISTA HÁBITOS -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ListaHabitos">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="8"
                                Margin="0,0,0,10" Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Nombre}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="#222"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="🔥" FontSize="12"/>
                                        <TextBlock Text="{Binding RachaDias, StringFormat='{}{0} días seguidos'}"
                                                   FontSize="12" Foreground="#0F6E56"
                                                   FontWeight="SemiBold" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1" Content="✓ Cumplí hoy"
                                        Margin="8,0" Padding="12,6"
                                        FontSize="12" Cursor="Hand"
                                        BorderThickness="0"
                                        Tag="{Binding Id}"
                                        Click="Cumplir_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#E1F5EE"/>
                                            <Setter Property="Foreground" Value="#0F6E56"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#C1EDD8"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Grid.Column="2" Content="🗑 Eliminar"
                                        Padding="12,6" FontSize="12" Cursor="Hand"
                                        BorderThickness="0"
                                        Tag="{Binding Id}"
                                        Click="Eliminar_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#FCEBEB"/>
                                            <Setter Property="Foreground" Value="#A32D2D"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F5C6C6"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>