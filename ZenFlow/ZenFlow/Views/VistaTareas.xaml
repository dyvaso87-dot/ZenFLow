<Page x:Class="ZenFlow.Views.VistaTareas"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Tareas">
    <StackPanel Margin="30">
        <TextBlock Text="Mis tareas" FontSize="22" FontWeight="Bold"
                   Foreground="#1F4E79" Margin="0,0,0,20"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox x:Name="TxtTitulo" Width="300" Height="34"
                     Padding="8,6" FontSize="13" Margin="0,0,10,0"
                     BorderBrush="#CCCCCC" BorderThickness="1"/>
            <DatePicker x:Name="DpFecha" Height="34" Margin="0,0,10,0"/>
            <Button Content="Agregar" Height="34" Padding="16,0"
                    Background="#1F4E79" Foreground="White"
                    BorderThickness="0" FontSize="13"
                    Click="AgregarTarea_Click"/>
        </StackPanel>
        <ListBox x:Name="ListaTareas" FontSize="13" BorderBrush="#CCCCCC"/>
    </StackPanel>
</Page>